function renderKPIs(){
  const total = DATA.length;
  const attrYes = DATA.filter(d=>d.Attrition==='Yes').length;
  const attrRate = rate(attrYes, total);
  const retRate = 100-attrRate;
  const avgIncome = mean(DATA.map(d=>d.MonthlyIncome).filter(v=>!isNaN(v)));
  const avgTenure = mean(DATA.map(d=>d.YearsAtCompany).filter(v=>!isNaN(v)));

  document.getElementById('hdrTotal').textContent = total.toLocaleString();
  document.getElementById('hdrAttr').textContent = attrRate.toFixed(1)+'%';
  document.getElementById('hdrRet').textContent = retRate.toFixed(1)+'%';

  const cards = [
    {h:'Total employees', v: total.toLocaleString(), s:'active + departed records'},
    {h:'Attrition rate', v: attrRate.toFixed(1)+'%', s: attrYes+' departures', cls:'up'},
    {h:'Retention rate', v: retRate.toFixed(1)+'%', s:(total-attrYes)+' retained', cls:'down'},
    {h:'Avg monthly income', v:'₹'+Math.round(avgIncome).toLocaleString(), s:'across all employees'},
  ];
  document.getElementById('kpiCards').innerHTML = cards.map(c=>`
    <div class="card"><h3>${c.h}</h3><div class="value">${c.v}</div><div class="sub ${c.cls||''}">${c.s}</div></div>
  `).join('');
}

