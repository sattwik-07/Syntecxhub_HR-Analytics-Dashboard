// ---------- CSV upload ----------
function parseCSV(text){
  const lines = text.replace(/\r/g,'').split('\n').filter(l=>l.length);
  const headers = lines[0].split(',').map(h=>h.trim());
  return lines.slice(1).map(line=>{
    const vals = line.split(',');
    const row = {};
    headers.forEach((h,i)=>{ row[h] = vals[i]!==undefined? vals[i].trim() : ''; });
    row._rawTravel = row.BusinessTravel;
    return row;
  });
}

document.getElementById('csvInput').addEventListener('change', (e)=>{
  const file = e.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = (ev)=>{
    try{
      const rows = parseCSV(ev.target.result);
      loadData(rows);
      document.getElementById('dataSourceLabel').innerHTML = `Currently showing: <b>${file.name}</b> (${rows.length.toLocaleString()} records)`;
    }catch(err){
      alert('Could not parse that CSV. Check the format and try again.');
    }
  };
  reader.readAsText(file);
});
