      </tr></thead><tbody></tbody></table>
    </div>
  </section>

  <!-- RISK MODEL -->
  <section class="tabpanel" id="tab-risk">
    <div class="section-title"><h2>Composite flight-risk score</h2></div>
    <div class="panel">
