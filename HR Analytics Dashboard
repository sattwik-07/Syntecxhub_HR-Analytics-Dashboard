      <div class="panel"><div class="chart-wrap"><canvas id="chartIncomeDist"></canvas></div></div>
      <div class="panel"><div class="chart-wrap"><canvas id="chartTenureDist"></canvas></div></div>
    </div>
  </section>

  <!-- ATTRITION PATTERNS -->
