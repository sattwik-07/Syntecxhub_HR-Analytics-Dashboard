<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0D131F;
    --panel:#151D2C;
    --panel-2:#1B2536;
    --line:#28334A;
    --text:#E7ECF3;
    --text-dim:#8592A6;
    --mint:#3DDC97;
    --coral:#FF6B5C;
    --amber:#F5C86B;
    --blue:#5B9CF6;
  }
  *{box-sizing:border-box;}
  body{margin:0;background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;}
  h1,h2,h3,.display{font-family:'Space Grotesk',sans-serif;}
  .mono{font-family:'IBM Plex Mono',monospace;}
  ::-webkit-scrollbar{width:8px;height:8px;}
  ::-webkit-scrollbar-thumb{background:var(--line);border-radius:4px;}

  header.top{
    padding:28px 40px 20px;
    border-bottom:1px solid var(--line);
    display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:16px;
  }
  .brand{display:flex; align-items:center; gap:12px;}
  .brand .mark{
    width:38px;height:38px;border-radius:8px;
    background:linear-gradient(135deg,var(--mint),var(--blue));
    display:flex;align-items:center;justify-content:center;
    font-family:'Space Grotesk';font-weight:700;color:#0D131F;font-size:18px;
  }
  .brand-text .eyebrow{font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--text-dim);font-family:'IBM Plex Mono';}
  .brand-text h1{font-size:22px;margin:2px 0 0;font-weight:600;}
  .top-meta{display:flex;gap:28px;flex-wrap:wrap;}
  .top-meta .stat{text-align:right;}
  .top-meta .stat .n{font-family:'IBM Plex Mono';font-size:20px;font-weight:600;}
  .top-meta .stat .l{font-size:11px;color:var(--text-dim);text-transform:uppercase;letter-spacing:.08em;}

  nav.tabs{
    display:flex; gap:4px; padding:14px 40px 0; border-bottom:1px solid var(--line);
    overflow-x:auto;
  }
  nav.tabs button{
    background:none;border:none;color:var(--text-dim);font-family:'Space Grotesk';font-size:14px;font-weight:600;
    padding:10px 16px;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;
    transition:color .15s, border-color .15s;
  }
  nav.tabs button:hover{color:var(--text);}
  nav.tabs button.active{color:var(--mint);border-bottom-color:var(--mint);}

  main{padding:28px 40px 60px; max-width:1400px; margin:0 auto;}
  .tabpanel{display:none;}
  .tabpanel.active{display:block; animation:fade .25s ease;}
  @keyframes fade{from{opacity:0; transform:translateY(4px);} to{opacity:1; transform:translateY(0);}}

  .grid{display:grid; gap:16px;}
  .grid-4{grid-template-columns:repeat(4,1fr);}
  .grid-3{grid-template-columns:repeat(3,1fr);}
  .grid-2{grid-template-columns:repeat(2,1fr);}
  @media(max-width:1000px){.grid-4{grid-template-columns:repeat(2,1fr);} .grid-3{grid-template-columns:repeat(2,1fr);} .grid-2{grid-template-columns:1fr;}}
  @media(max-width:600px){.grid-4{grid-template-columns:1fr;}}

  .card{
    background:var(--panel); border:1px solid var(--line); border-radius:10px; padding:18px 20px;
  }
  .card h3{margin:0 0 4px; font-size:13px; text-transform:uppercase; letter-spacing:.06em; color:var(--text-dim); font-weight:600;}
  .card .value{font-family:'IBM Plex Mono'; font-size:30px; font-weight:600; margin:6px 0 2px;}
  .card .sub{font-size:12px; color:var(--text-dim);}
  .card .sub.up{color:var(--coral);}
  .card .sub.down{color:var(--mint);}

  .section-title{display:flex; align-items:baseline; gap:10px; margin:36px 0 14px;}
  .section-title h2{font-size:18px; margin:0; font-weight:600;}
  .section-title .num{font-family:'IBM Plex Mono'; color:var(--text-dim); font-size:13px;}
  .section-title:first-child{margin-top:0;}

  .panel{background:var(--panel); border:1px solid var(--line); border-radius:10px; padding:20px 22px;}
  .panel + .panel{margin-top:16px;}
  .chart-wrap{position:relative; height:300px;}
  .chart-wrap.tall{height:380px;}
  .note{font-size:12.5px; color:var(--text-dim); line-height:1.55; margin-top:10px;}
  .note b{color:var(--text);}

  .badge{display:inline-flex; align-items:center; gap:5px; font-family:'IBM Plex Mono'; font-size:11px; padding:3px 9px; border-radius:20px; font-weight:500;}
  .badge.high{background:rgba(255,107,92,.15); color:var(--coral); border:1px solid rgba(255,107,92,.35);}
  .badge.med{background:rgba(245,200,107,.15); color:var(--amber); border:1px solid rgba(245,200,107,.35);}
  .badge.low{background:rgba(61,220,151,.15); color:var(--mint); border:1px solid rgba(61,220,151,.35);}

  table{width:100%; border-collapse:collapse; font-size:13px;}
  th{text-align:left; font-family:'IBM Plex Mono'; font-size:11px; text-transform:uppercase; letter-spacing:.06em; color:var(--text-dim); padding:8px 10px; border-bottom:1px solid var(--line); position:sticky; top:0; background:var(--panel);}
  td{padding:9px 10px; border-bottom:1px solid var(--panel-2);}
  tr:hover td{background:var(--panel-2);}
  .table-scroll{max-height:440px; overflow:auto; border:1px solid var(--line); border-radius:8px;}
  .risk-bar{width:70px; height:6px; background:var(--panel-2); border-radius:3px; overflow:hidden; display:inline-block; vertical-align:middle; margin-right:8px;}
  .risk-bar span{display:block; height:100%; background:var(--coral);}

  .upload-box{
    border:1.5px dashed var(--line); border-radius:10px; padding:20px; text-align:center; cursor:pointer;
    transition:border-color .15s, background .15s;
  }
  .upload-box:hover{border-color:var(--mint); background:rgba(61,220,151,.04);}
  .upload-box input{display:none;}
  .flex-between{display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap;}
  .btn{
    background:var(--mint); color:#0D131F; border:none; padding:9px 16px; border-radius:7px; font-weight:600;
    font-family:'Space Grotesk'; font-size:13px; cursor:pointer;
  }
  .btn.secondary{background:transparent; color:var(--text); border:1px solid var(--line);}
  select, input[type=text]{
    background:var(--panel-2); border:1px solid var(--line); color:var(--text); padding:8px 10px; border-radius:7px;
    font-family:'Inter'; font-size:13px;
  }
  .filters{display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px;}
  .legend-dot{display:inline-block; width:9px; height:9px; border-radius:50%; margin-right:6px;}
  .two-col{display:grid; grid-template-columns:1.3fr 1fr; gap:16px;}
  @media(max-width:1000px){.two-col{grid-template-columns:1fr;}}
  .quality-item{display:flex; gap:12px; padding:12px 0; border-bottom:1px solid var(--panel-2);}
  .quality-item:last-child{border-bottom:none;}
  .quality-item .icon{font-family:'IBM Plex Mono'; font-size:16px; color:var(--amber); width:22px;}
  footer{padding:20px 40px 40px; color:var(--text-dim); font-size:12px; text-align:center;}
</style>
</head>
<body>

<header class="top">
  <div class="brand">
    <div class="mark">H</div>
    <div class="brand-text">
      <div class="eyebrow">Syntecxhub</div>
      <h1>HR Analytics Dashboard</h1>
    </div>
  </div>
  <div class="top-meta">
    <div class="stat"><div class="n mono" id="hdrTotal">—</div><div class="l">Employees</div></div>
    <div class="stat"><div class="n mono" id="hdrAttr">—</div><div class="l">Attrition Rate</div></div>
    <div class="stat"><div class="n mono" id="hdrRet">—</div><div class="l">Retention Rate</div></div>
  </div>
</header>

<nav class="tabs">
  <button class="tab-btn active" data-tab="overview">Overview</button>
  <button class="tab-btn" data-tab="attrition">Attrition Patterns</button>
  <button class="tab-btn" data-tab="correlation">Correlation Analysis</button>
  <button class="tab-btn" data-tab="deptrole">Department &amp; Role</button>
