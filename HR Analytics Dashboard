function destroy(id){ if(charts[id]){ try{ charts[id].destroy(); }catch(e){} delete charts[id]; } }

function safeChart(id, config){
  const canvas = document.getElementById(id);
  if(!canvas) return null;
  if(!CHART_AVAILABLE){
    if(canvas.parentElement){
      canvas.parentElement.innerHTML = '<div class="note" style="padding-top:36px;text-align:center;">Chart library failed to load from the CDN (check your internet connection). Everything else on this page is unaffected.</div>';
    }
    return null;
  }
  try{
    return new Chart(canvas, config);
  }catch(e){
    console.error('Chart render failed for', id, e);
    if(canvas.parentElement){
      canvas.parentElement.innerHTML = '<div class="note" style="padding-top:36px;text-align:center;">This chart failed to render. Check the browser console for details.</div>';
    }
    return null;
  }
}

function normalizeRow(d){
  const out = Object.assign({}, d);
  NUMERIC_FIELDS.forEach(f=>{
    if(out[f] !== undefined && out[f] !== null && out[f] !== ''){
      out[f] = typeof out[f]==='number' ? out[f] : parseFloat(out[f]);
    }
  });
  // normalize BusinessTravel typo variant
  if(out.BusinessTravel === 'TravelRarely') out.BusinessTravel = 'Travel_Rarely';
  return out;
}

function loadData(rows){
  DATA = rows.map(normalizeRow);
  renderAll();
}

// ---------- stats helpers ----------
function mean(arr){ return arr.length ? arr.reduce((a,b)=>a+b,0)/arr.length : 0; }
function rate(sub, whole){ return whole ? (sub/whole*100) : 0; }

function pointBiserial(field){
  const xs=[], ys=[];
  DATA.forEach(d=>{
    const v = d[field];
    if(v===undefined||v===null||isNaN(v)) return;
    xs.push(v); ys.push(d.Attrition==='Yes'?1:0);
  });
  const n = xs.length; if(n<2) return 0;
  const mx = mean(xs), my = mean(ys);
  let cov=0, vx=0, vy=0;
  for(let i=0;i<n;i++){ cov += (xs[i]-mx)*(ys[i]-my); vx += (xs[i]-mx)**2; vy += (ys[i]-my)**2; }
  const denom = Math.sqrt(vx*vy);
  return denom ? cov/denom : 0;
}

function groupRates(field, order){
  const g = {};
  DATA.forEach(d=>{
    const k = d[field];
    if(k===undefined||k===null||k==='') return;
    if(!g[k]) g[k] = [0,0];
    g[k][1]++;
    if(d.Attrition==='Yes') g[k][0]++;
  });
  let entries = Object.entries(g).map(([k,v])=>({label:k, left:v[1]-v[0], attr:v[0], total:v[1], rate:rate(v[0],v[1])}));
  if(order) entries.sort((a,b)=> order.indexOf(a.label)-order.indexOf(b.label));
  else entries.sort((a,b)=> b.rate - a.rate);
  return entries;
}

function barRateChart(canvasId, entries, colorFn){
  destroy(canvasId);
  charts[canvasId] = safeChart(canvasId, {
    type:'bar',
    data:{
      labels: entries.map(e=>e.label),
      datasets:[{
        label:'Attrition rate %',
        data: entries.map(e=>e.rate.toFixed(1)),
        backgroundColor: entries.map((e,i)=> colorFn ? colorFn(e,i) : (e.rate>20?COLORS.coral:e.rate>12?COLORS.amber:COLORS.mint)),
        borderRadius:5, maxBarThickness:46
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{legend:{display:false}, tooltip:{callbacks:{ afterLabel:(c)=>{
        const e = entries[c.dataIndex]; return `${e.attr} left / ${e.total} total`;
      }}}},
      scales:{ y:{beginAtZero:true, ticks:{callback:v=>v+'%'}, grid:{color:COLORS.grid}}, x:{grid:{display:false}} }
    }
  });
}

