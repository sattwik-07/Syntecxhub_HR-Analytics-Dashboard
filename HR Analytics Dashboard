    </div>
  </section>

  <!-- CORRELATION -->
  <section class="tabpanel" id="tab-correlation">
    <div class="section-title"><h2>What actually predicts attrition</h2><span class="num">point-biserial correlation vs Attrition=Yes</span></div>
