// ---------- risk model ----------
let riskRows = [];
function computeRiskModel(){
  const corrFields = ['TotalWorkingYears','JobLevel','YearsWithCurrManager','YearsInCurrentRole','MonthlyIncome',
    'Age','YearsAtCompany','StockOptionLevel','JobInvolvement','JobSatisfaction','EnvironmentSatisfaction'];
  const corrs = {};
  corrFields.forEach(f=> corrs[f] = pointBiserial(f));

  const stats = {};
  corrFields.forEach(f=>{
    const vals = DATA.map(d=>d[f]).filter(v=>!isNaN(v));
    stats[f] = {min:Math.min(...vals), max:Math.max(...vals)};
  });

  const active = DATA.filter(d=>d.Attrition==='No');
  riskRows = active.map(d=>{
    let score = 0, weightSum=0;
    corrFields.forEach(f=>{
      const v = d[f];
      if(v===undefined||isNaN(v)) return;
      const {min,max} = stats[f];
      const norm = max>min ? (v-min)/(max-min) : 0.5;
      // if corr negative, higher value = lower risk -> risk contribution = (1-norm); if positive corr, risk = norm
      const contrib = corrs[f] < 0 ? (1-norm) : norm;
      const w = Math.abs(corrs[f]);
      score += contrib * w;
      weightSum += w;
    });
    // categorical boosts
    let catBoost = 0;
    if(d.OverTime==='Yes') catBoost += 0.12;
    if(d.MaritalStatus==='Single') catBoost += 0.06;
    if(d.BusinessTravel==='Travel_Frequently') catBoost += 0.05;
    const base = weightSum ? score/weightSum : 0;
    const final = Math.min(1, base*0.75 + catBoost);
    return Object.assign({}, d, {riskScore: final});
  }).sort((a,b)=> b.riskScore - a.riskScore);

  const n = riskRows.length;
  const highCut = Math.floor(n*0.15);
  const medCut = Math.floor(n*0.45);
  riskRows.forEach((r,i)=>{ r.riskTier = i<highCut ? 'High' : i<medCut ? 'Medium' : 'Low'; });

  document.getElementById('riskHighCount').textContent = highCut;
  document.getElementById('riskMedCount').textContent = (medCut-highCut);
  document.getElementById('riskLowCount').textContent = (n-medCut);

  const deptSel = document.getElementById('riskDeptFilter');
  const depts = [...new Set(DATA.map(d=>d.Department))];
  deptSel.innerHTML = '<option value="">All departments</option>' + depts.map(d=>`<option value="${d}">${d}</option>`).join('');
  deptSel.onchange = renderRiskTable;
  renderRiskTable();
}

function renderRiskTable(){
  const filterDept = document.getElementById('riskDeptFilter').value;
  const rows = riskRows.filter(r=> !filterDept || r.Department===filterDept).slice(0,25);
  const tbody = document.querySelector('#riskTable tbody');
  tbody.innerHTML = rows.map(r=>{
    const tierClass = r.riskTier==='High'?'high':r.riskTier==='Medium'?'med':'low';
    return `<tr>
      <td class="mono">${r.EmpID||'—'}</td><td>${r.Department}</td><td>${r.JobRole}</td>
      <td>${r.YearsAtCompany}</td><td>₹${Math.round(r.MonthlyIncome).toLocaleString()}</td>
      <td>${r.JobSatisfaction}/4</td><td>${r.OverTime}</td>
      <td><span class="risk-bar"><span style="width:${(r.riskScore*100).toFixed(0)}%"></span></span><span class="badge ${tierClass}">${r.riskTier}</span></td>
    </tr>`;
  }).join('');
}

// ---------- data quality ----------
function renderDataQuality(){
  const idCounts = {};
  DATA.forEach(d=>{ const id=d.EmpID; if(!id) return; idCounts[id]=(idCounts[id]||0)+1; });
  const dupIds = Object.entries(idCounts).filter(([k,v])=>v>1);

  const travelTypo = DATA.filter(d=>d._rawTravel==='TravelRarely').length;

  const missing = {};
  Object.keys(DATA[0]||{}).forEach(f=>{
    const m = DATA.filter(d=> d[f]===undefined||d[f]===null||d[f]==='').length;
    if(m>0) missing[f]=m;
  });

  const items = [];
  if(dupIds.length>0){
    items.push({icon:'⚠', text:`<b>${dupIds.length} duplicate EmpID${dupIds.length>1?'s':''}</b> found (${dupIds.length*2} rows total). Each pair is near-identical but differs in one field (usually YearsWithCurrManager) — this looks like duplicated records with a perturbed field rather than genuinely different employees. They were <b>not</b> removed automatically; all KPIs above still include them. Worth deduplicating before this feeds any real HR decision.`});
  }
  if(travelTypo>0){
    items.push({icon:'⚠', text:`<b>${travelTypo} rows</b> had "TravelRarely" as a distinct category from "Travel_Rarely" — same value, inconsistent spelling. This dashboard normalizes them together; a raw groupby would silently undercount one bucket.`});
  }
  const outOfRange = DATA.filter(d=> d.Age<18 || d.Age>65).length;
  if(outOfRange>0){
    items.push({icon:'⚠', text:`${outOfRange} employees fall outside a typical 18–65 working age range — worth a sanity check if this feeds a model.`});
  }
  if(Object.keys(missing).length>0){
    items.push({icon:'⚠', text:`Missing values detected in: ${Object.keys(missing).map(f=>`${f} (${missing[f]})`).join(', ')}.`});
  }
  if(items.length===0){
    items.push({icon:'✓', text:'No structural data quality issues detected in the current dataset.'});
  }
  document.getElementById('qualityPanel').innerHTML = items.map(i=>`
    <div class="quality-item"><div class="icon">${i.icon}</div><div class="note" style="margin-top:0;">${i.text}</div></div>
  `).join('');
}

